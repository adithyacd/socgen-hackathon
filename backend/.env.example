# Copy to backend/.env and fill in. The app runs fully WITHOUT a key
# (narratives/copilot fall back to deterministic templates + cached results).
ANTHROPIC_API_KEY=
# Model used for narratives + copilot when a key is present.
SENTINEL_LLM_MODEL=claude-sonnet-4-5
# Where generated data + cached LLM output live (relative to repo root).
SENTINEL_DATA_DIR=data
